node_modules/
dist/
build/
.env
.env.*
!.env.example
*.log
.DS_Store

# Private allowlist credentials -- never commit a payee's secret/amount/path.
credentials/
*.credential.json
.payroll/

# Exception: the "Try it yourself" judge-testable demo payroll is
# deliberately public (a disposable testnet payroll, not a real one) --
# see README "Try it yourself".
