!docs/try-it-yourself/credentials/
!docs/try-it-yourself/credentials/*.json

# Midnight network state: per-network wallet SEED and deployment address.
# The seed is sensitive; treat this file like a private key.
.midnight-state.json

# Serialized wallet sync-state cache (per network).
.midnight-wallet-state/

# Local private-state LevelDB store (levelPrivateStateProvider).
midnight-level-db/

.vercel/
coverage/

# Claude Code harness-local state
.claude/
