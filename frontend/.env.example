# Which Midnight network the dashboard reads from: undeployed | preview | preprod
VITE_NETWORK=preprod

# The deployed Shadow Payroll contract address on that network.
VITE_CONTRACT_ADDRESS=

# Where the browser's claim flow reaches a proof-server (Lace doesn't yet
# support in-wallet proving). Default is the same local docker-compose
# proof-server the root CLI uses.
VITE_PROOF_SERVER_URL=http://127.0.0.1:6300
